# Supabase project credentials for the QRCodeAdmin mobile app.
# Copy to .env and fill in. These are PUBLIC (anon) values only.
# NEVER put the service_role key here: all writes go through the
# authenticated user session and are enforced by Supabase RLS.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Public web origin the app talks to (admin API, real-render + QA WebViews).
# Optional — defaults to https://cenacrew.com. Override to point the app at a
# Vercel preview when validating the multi-zone cutover.
# EXPO_PUBLIC_BASE_URL=https://cenacrew.com
